{
  "name": "@portvision/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "lint": "tsc --noEmit",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "seed": "node --env-file-if-exists=.env --import tsx src/seed.ts",
    "prisma": "prisma"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@portvision/shared": "workspace:*",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.0",
    "pino-pretty": "^11.2.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.12",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
